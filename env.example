# =========================================================================
# TELEGRAM UI BOT & TELEGRAM MESSAGING
# =========================================================================
BOT_TOKEN=1234567890:ABCdefGhIJKlmNoPQRsTUVwXyZ     # Токен официального бота, полученный от @BotFather
ADMIN_CHAT_ID=987654321                             # Твой личный Telegram ID (сюда Alertmanager будет слать критические алерты)

# =========================================================================
# PYROGRAM USERBOT (SCRAPER SUBSYSTEM)
# =========================================================================
API_ID=1234567                                      # API ID, полученный на https://my.telegram.org
API_HASH=abcdef0123456789abcdef0123456789          # API Hash, полученный на https://my.telegram.org
GROUP_ID=-1001234567890                             # ID донорского Telegram-канала/группы, откуда скрейпим посты

# Строка сессии Pyrogram (необязательно). Используй для деплоя на PaaS/K8s,
# где нельзя или неудобно хранить физический файл twink_account.session
PYROGRAM_SESSION_STRING=

# =========================================================================
# INFRASTRUCTURE CORE (DATABASE & BROKER)
# =========================================================================
# ВАЖНО: Используем асинхронный драйвер postgresql+asyncpg для SQLAlchemy 2.0
DATABASE_URL=postgresql+asyncpg://postgres.your_project_id:your_password@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
REDIS_URL=redis://redis:6379/0                      # Внутри Docker-сети хост брокера жестко называется 'redis'

# =========================================================================
# OBSERVABILITY & PROMETHEUS METRICS PORTS
# =========================================================================
GRAFANA_PASSWORD=super_secure_admin_password_2026   # Пароль администратора для входа в веб-панель Grafana

# Порты экспортеров метрик. Должны быть строго уникальными (модель-валидатор Pydantic проверяет это на старте)
METRICS_PORT_WORKER=8000                            # Прометей-порт подсистемы анализа и рассылки
METRICS_PORT_SCRAPER=8001                           # Прометей-порт подсистемы захвата постов
METRICS_PORT_BOT=8002                               # Прометей-порт подсистемы интерфейса настроек бота

# =========================================================================
# BUSINESS LOGIC & QUIET HOURS (NIGHT MODE)
# =========================================================================
NIGHT_START_HOUR=22                                 # Час запуска ночного режима тишины (0-23). Сообщения станут беззвучными.
NIGHT_END_HOUR=7                                    # Час завершения ночного режима тишины (0-23).
TELEGRAM_MAX_RETRY_SECONDS=180                      # Лимит кумулятивного сна воркера при поимке Flood Control (429)

# =========================================================================
# PRODUCTION LOGGING ENGINE
# =========================================================================
LOG_LEVEL=INFO                                      # Порог логирования: DEBUG (для тестов), INFO, WARNING, ERROR, CRITICAL
LOG_DIR=/data/logs                                  # Директория внутри контейнеров, куда пишутся структурные JSON-логи
LOG_MAX_BYTES=20971520                              # Буфер ротации одного файла (20971520 байт = 20 МБ)
LOG_BACKUP_COUNT=5                                  # Глубина архива ротации (хранить до 5 старых файлов логов на сервис)