# =========================================================================
# APPLICATION CORE & SECURITY KEYS
# =========================================================================
# Уникальный секретный ключ приложения для криптографических задач (HMAC, соли)
APP_SECRET_KEY="super_secure_random_hex_or_string_change_me"

# =========================================================================
# TELEGRAM UI BOT & TELEGRAM MESSAGING
# =========================================================================
# Токен официального бота, полученный от @BotFather
BOT_TOKEN="1234567890:ABCdefGhIJKlmNoPQRsTUVwXyZ"
# Твой личный Telegram ID для отправки системных уведомлений из Alertmanager
ADMIN_CHAT_ID=987654321

# =========================================================================
# PYROGRAM USERBOT (SCRAPER SUBSYSTEM)
# =========================================================================
# Данные приложения, полученные на https://my.telegram.org
API_ID=1234567
API_HASH="abcdef0123456789abcdef0123456789"
# ID донорского Telegram-канала/группы, откуда скрейпим посты
GROUP_ID=-1001234567890
# Строка сессии Pyrogram (необязательно, для деплоя в PaaS/K8s)
PYROGRAM_SESSION_STRING=""

# =========================================================================
# INFRASTRUCTURE CORE (DATABASE & BROKER)
# =========================================================================
# ВАЖНО: Для Transaction Mode пулера Supabase (порт 6543) ОБЯЗАТЕЛЬНО отключаем кэш выражений на конце URL
DATABASE_URL="postgresql+asyncpg://postgres.your_id:password@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?prepared_statement_cache_size=0"

# Лимиты пула подключений SQLAlchemy (настраиваются под мощность сервера)
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Настройки брокера Redis
REDIS_URL="redis://:super_secure_redis_password_2026@redis:6379/0"

# =========================================================================
# OBSERVABILITY STACK PORTS (HOST BINDINGS)
# =========================================================================
# Пароль администратора для входа в веб-панель Grafana
GRAFANA_PASSWORD="super_secure_admin_password_2026"

# Порты привязки сервисов на хост-машине (чтобы избежать конфликтов портов на сервере)
HOST_PORT_GRAFANA=3000
HOST_PORT_PROMETHEUS=9090
HOST_PORT_ALERTMANAGER=9093

# Внутренние порты экспортеров метрик Pydantic (должны быть уникальными)
METRICS_PORT_WORKER=8000
METRICS_PORT_SCRAPER=8001
METRICS_PORT_BOT=8002

# =========================================================================
# BUSINESS LOGIC & QUIET HOURS (NIGHT MODE)
# =========================================================================
# Часы запуска и завершения ночного режима тишины (0-23)
NIGHT_START_HOUR=22
NIGHT_END_HOUR=7
# Лимит кумулятивного сна воркера при поимке Flood Control (429)
TELEGRAM_MAX_RETRY_SECONDS=180

# =========================================================================
# PRODUCTION LOGGING ENGINE
# =========================================================================
LOG_LEVEL="INFO"
LOG_DIR="/data/logs"
LOG_MAX_BYTES=20971520
LOG_BACKUP_COUNT=5