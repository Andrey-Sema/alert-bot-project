{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "options": { "legend": { "displayMode": "list" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "rate(worker_alerts_processed_total[5m])",
          "legendFormat": "Alerts/sec"
        }
      ],
      "title": "🚨 Alerts Dispatched (rate/5m)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "targets": [
        {
          "expr": "rate(scraper_messages_total[5m])",
          "legendFormat": "Messages/sec"
        },
        {
          "expr": "rate(scraper_errors_total[5m])",
          "legendFormat": "Errors/sec"
        }
      ],
      "title": "📡 Scraper Throughput",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          },
          "mappings": [],
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 },
      "id": 3,
      "options": { "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "table": false,
          "expr": "max_over_time(worker_dlq_size[1m])",
          "legendFormat": "DLQ Size (Пик)"
        }
      ],
      "title": "☠️ Dead Letter Queue Depth",
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "s" }
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 8 },
      "id": 4,
      "options": { "reduceOptions": { "calcs": ["p95"] } },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(worker_processing_duration_seconds_bucket[5m]))",
          "legendFormat": "p95 Latency"
        },
        {
          "expr": "rate(worker_processing_duration_seconds_sum[5m]) / rate(worker_processing_duration_seconds_count[5m])",
          "legendFormat": "Avg Latency"
        }
      ],
      "title": "⏱️ Processing Latency (p95 & Avg)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short" }
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 },
      "id": 5,
      "targets": [
        {
          "expr": "rate(worker_errors_total[5m])",
          "legendFormat": "Worker errors/sec"
        },
        {
          "expr": "rate(scraper_errors_total[5m])",
          "legendFormat": "Scraper errors/sec"
        }
      ],
      "title": "💥 Error Rate (Real-time / 5m)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short" }
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 8 },
      "id": 6,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "increase(worker_alerts_processed_total[24h])",
          "legendFormat": "Alerts today"
        }
      ],
      "title": "📊 Total Alerts (24h)",
      "type": "stat"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "tags": ["odesa-alert", "production"],
  "templating": { "list": [] },
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
  "timezone": "Europe/Kyiv",
  "title": "OdesaAlert Production Dashboard",
  "uid": "odesa-alert-main",
  "version": 2
}