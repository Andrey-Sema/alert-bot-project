# ============================================================
#  Системный Python кэш и изоляция окружения
# ============================================================
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
.eggs/
dist/
build/

.venv/
venv/
env/
.python-version

# ============================================================
#  Секреты, Конфиги и Токены (КРИТИЧЕСКИ ВАЖНО)
# ============================================================
.env
.env.*
*.env
!.env.example
!.env.template

# Сессии Pyrogram / Telegram
*.session
*.session-journal

# ============================================================
#  Базы данных, Бэкапы и Дампы (Защита от утечки данных)
# ============================================================
# Только дампы и бэкапы, но НЕ миграции
*.dump
*.dump.sql
*.sql.gz
backup*.sql
export*.sql
backup*.tar
*.tar.gz
*.tar.bz2
*.db
*.sqlite
*.sqlite3

# ============================================================
#  Docker и Локальная Оркестрация
# ============================================================
docker-compose.override.yml
docker-compose.local.yml
docker-compose.dev.yml
.dockerignore.local

# ============================================================
#  Runtime Данные и Логи контейнеров
# ============================================================
data/
logs/
!data/.gitkeep
!logs/.gitkeep
*.log
*.pid

# ============================================================
#  IDE / Редакторы (PyCharm, VS Code)
# ============================================================
.idea/
*.iml
*.iws
*.ipr
.vscode/
*.code-workspace
.history/

# ============================================================
#  Тестирование, Линтеры и Статический Анализ
# ============================================================
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
test-results/

.mypy_cache/
.ruff_cache/

# ============================================================
#  Мусор операционных систем
# ============================================================
# macOS
.DS_Store
._*

# Windows
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~
.fuse_hidden*
.directory

# ============================================================
#  Большие файлы и архивы
# ============================================================
*.zip
*.7z
*.rar
*.mp4
*.avi
*.mov